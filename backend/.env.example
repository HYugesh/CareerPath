# Database
MONGO_URI=mongodb://localhost:27017/ai-learning-platform

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Google AI (Gemini) - Primary AI for roadmap generation
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI - Fallback for roadmap generation when Gemini fails, also used for Voice features (Whisper STT & TTS)
OPENAI_API_KEY=your_openai_api_key_here

# Code Execution - Judge0 API (Free tier available)
# Get a free API key from https://rapidapi.com/judge0-official/api/judge0-ce
# Or use the free public endpoint (no key needed, but has rate limits)
JUDGE0_API_KEY=
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# Alternative: Use Sphere Engine (if you have an account)
# JUDGE0_API_URL=https://your-sphere-engine-url.com

# Server
PORT=5001
NODE_ENV=development
