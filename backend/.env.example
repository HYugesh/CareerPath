# Database
MONGO_URI=mongodb://localhost:27017/ai-learning-platform

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Google AI (Gemini) - Primary AI for roadmap generation
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI - Fallback for roadmap generation when Gemini fails, also used for Voice features (Whisper STT & TTS)
OPENAI_API_KEY=your_openai_api_key_here

# Server
PORT=5001
NODE_ENV=development